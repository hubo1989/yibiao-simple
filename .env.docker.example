# AI 写标书助手 Docker 部署配置
# 复制此文件为 .env 并修改配置值

# ==================== 数据库配置 ====================
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=yibiao
# 宿主机暴露的 PostgreSQL 端口；本机已有 PostgreSQL 时可改为 15432 等
DB_PORT=5432

# ==================== 安全配置 ====================
# JWT 密钥：生成方式 `openssl rand -hex 32`
SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_hex_32

# 数据加密密钥：用于加密 API Keys 等敏感数据
# 生成方式 `openssl rand -hex 32`
ENCRYPTION_KEY=your_encryption_key_here_generate_with_openssl_rand_hex_32

# ==================== 应用配置 ====================
# 调试模式（生产环境请设为 false）
DEBUG=false

# 默认生成模型
DEFAULT_MODEL=deepseek-chat

# ==================== LLM 配置（OpenAI-compatible） ====================
# 适用于 OpenAI、DeepSeek、Qwen、Ollama OpenAI API、vLLM、Xinference 等兼容接口
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-your-api-key
LLM_MODEL=deepseek-chat
LLM_MODELS=deepseek-chat,deepseek-reasoner

# ==================== Embedding 配置 ====================
# ollama: 使用 OllamaEmbedding；openai-compatible: 使用 OpenAI-compatible embeddings
EMBEDDING_PROVIDER=ollama
EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_API_KEY=
EMBEDDING_MODEL=qwen3-embedding:4b
EMBEDDING_MODELS=qwen3-embedding:4b
EMBEDDING_DIMENSION=2560

# ==================== Bid Agent 配置 ====================
# 默认使用确定性章节生成，保证自托管一键流程稳定收口。
# 如需逐章节调用 LLM，可改为 true，并按上游速度调大超时时间。
BID_AGENT_USE_LLM_CHAPTERS=false
BID_AGENT_CHAPTER_TIMEOUT_SECONDS=15

# ==================== 认证配置 ====================
# 访问令牌过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 刷新令牌过期时间（天）
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== CORS 配置 ====================
# 允许的跨域来源，多个用逗号分隔
CORS_ORIGINS=http://localhost,http://localhost:80,https://yourdomain.com

# ==================== 端口配置 ====================
# FastAPI 应用对外暴露端口；本地自托管默认不需要 Nginx
PORT=8000

# 如需启用反向代理，可使用：
# docker compose --profile reverse-proxy up -d --build
# NGINX_PORT=80
